# Application
APP_NAME="AI Academic Assistant"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database
# SQLite for development (file-based)
DATABASE_URL=sqlite+aiosqlite:///./academic_assistant.db
# PostgreSQL for production (uncomment and configure for deployment)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/academic_assistant

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Provider: "ollama" (local) or "groq" (cloud)
LLM_PROVIDER=ollama

# Ollama Configuration (for local LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=4096

# Groq Configuration (for cloud LLM_PROVIDER=groq)
# Get your free API key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# CORS (Frontend URL)
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "https://ai-assistance-for-students.vercel.app"]

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=["pdf", "docx", "pptx", "txt", "md"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json